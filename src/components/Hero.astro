---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { client } from '../data/client';
import { heroImage as localHeroImage } from '../config/images';

// Am schimbat placeholder-ul cu o imagine de vilă/piscină mai apropiată de vibe-ul Costa Blanca
const PLACEHOLDER = 'https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=1200&q=80';

interface Props {
  topper?: string;
  heading?: string;
  description?: string;
  ctaLabel?: string;
  ctaHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  imageSrc?: ImageMetadata | string;
  imageAlt?: string;
}

const {
  topper = 'Expertiză Locală & Garanție',
  heading = 'Casa ta din Spania, pe mâini sigure.',
  description = 'Administrare completă, mentenanță auto și protecție legală în Torrevieja și Orihuela Costa. Ne ocupăm de proprietatea ta, ca tu să te bucuri doar de soare.',
  ctaLabel = 'Ofertă pe WhatsApp',
  ctaHref = `https://wa.me/${client.phoneForTel.replace(/-/g, '')}?text=Salut%20Stelian!%20Vreau%20sa%20discutam%20despre%20administrarea%20casei%20mele%20din%20Costa%20Blanca.`,
  secondaryLabel = 'Pachete Servicii',
  secondaryHref = '/services',
  imageSrc = localHeroImage ?? PLACEHOLDER,
  imageAlt = 'Vila de lux in Costa Blanca Spania',
} = Astro.props;
---

<section class="relative overflow-hidden bg-background py-12 sm:py-16 md:py-20 lg:py-24 font-heading">
  <div class="mx-auto grid max-w-site grid-cols-1 items-center gap-8 px-4 sm:px-6 lg:grid-cols-2 lg:gap-12">

    <div class="order-2 space-y-5 lg:order-1 lg:space-y-6">
      {topper && (
        <span class="inline-block rounded-full bg-accent/10 px-4 py-1.5 text-topper font-bold uppercase tracking-widest text-accent">
          {topper}
        </span>
      )}

      <h1
        class="font-heading text-display font-bold uppercase leading-tight tracking-tight text-text"
        transition:name="hero-heading"
      >
        {heading}
      </h1>

      <p class="max-w-lg text-lead text-text-muted leading-relaxed">
        {description}
      </p>

      <div class="flex flex-col gap-3 pt-2 sm:flex-row sm:items-center sm:gap-4">
        <a
          href={ctaHref}
          target="_blank"
          class="inline-flex min-h-[44px] items-center justify-center rounded-md bg-blue-600 px-6 py-3 text-base font-bold text-white shadow-lg transition-all hover:bg-blue-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >
          {ctaLabel}
        </a>
        <a
          href={secondaryHref}
          class="inline-flex min-h-[44px] items-center justify-center rounded-md border-2 border-slate-900 px-6 py-3 text-base font-bold text-slate-900 transition-colors hover:bg-slate-900 hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        >
          {secondaryLabel}
        </a>
      </div>

      <a
        href={`tel:${client.phoneForTel}`}
        class="inline-flex items-center gap-2 pt-1 text-sm font-semibold text-text-muted transition-colors hover:text-blue-600"
      >
        <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Sună acum: {client.phoneFormatted}
      </a>
    </div>

    <div
      class="relative order-1 overflow-hidden rounded-2xl shadow-2xl aspect-4/3 lg:order-2"
      transition:name="hero-image"
    >
      <Image
        src={imageSrc}
        alt={imageAlt}
        width={800}
        height={600}
        loading="eager"
        decoding="async"
        class="size-full object-cover"
      />
    </div>
  </div>
</section>
