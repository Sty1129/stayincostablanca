---
/* Componenta de Servicii - Versiunea 100% Curată (RO/EN) */
const currentLang = Astro.currentLocale || 'ro';

const translations = {
  ro: {
    title: "Pachete de Administrare",
    subtitle: "Soluții profesionale pentru liniștea ta în Costa Blanca.",
    perYear: "/an",
    mostPopular: "Cel mai popular",
    everythingIn: "Tot din",
    ctaPearl: "Solicită Pearl",
    ctaSapphire: "Alege Sapphire",
    ctaEmerald: "Rezervă Emerald",
    waPearl: "Salut! Vreau pachetul PEARL",
    waSapphire: "Salut! Vreau pachetul SAPPHIRE",
    waEmerald: "Salut! Vreau pachetul EMERALD",
    pearlFeatures: [
      "Păstrare chei 24/7 (Key Holding)",
      "1 vizită lunară (interior/exterior)",
      "Verificare post-furtună/ploi",
      "Raport foto/video pe WhatsApp",
      "Colectare corespondență & facturi"
    ],
    sapphireFeatures: [
      "2 vizite lunare detaliate",
      "Management facturi (Suma/Ibi)",
      "Reprezentare la Comunitate",
      "Gestiune echipe mentenanță",
      "Aerisire & verificare instalații"
    ],
    emeraldFeatures: [
      "🛡️ Protocol Anti-Okupas (vizite 48h)",
      "Digital Twin (Scanare 360°)",
      "Concierge (Pregătire sosire)",
      "Asistență prioritară 4h",
      "Gestiune închirieri (la cerere)"
    ]
  },
  en: {
    title: "Management Packages",
    subtitle: "Professional solutions for your peace of mind in Costa Blanca.",
    perYear: "/year",
    mostPopular: "Most Popular",
    everythingIn: "Everything in",
    ctaPearl: "Request Pearl",
    ctaSapphire: "Choose Sapphire",
    ctaEmerald: "Book Emerald",
    waPearl: "Hi! I'm interested in the PEARL package",
    waSapphire: "Hi! I'm interested in the SAPPHIRE package",
    waEmerald: "Hi! I'm interested in the EMERALD package",
    pearlFeatures: [
      "24/7 Secure Key Holding",
      "1 Monthly inspection",
      "Post-storm/rain verification",
      "Photo/video WhatsApp report",
      "Mail & utility bill collection"
    ],
    sapphireFeatures: [
      "2 Detailed monthly visits",
      "Bill & tax management (Suma/Ibi)",
      "Community meeting attendance",
      "Maintenance team management",
      "Property airing & utility check"
    ],
    emeraldFeatures: [
      "🛡️ Anti-Squatter Protocol (48h visits)",
      "Digital Twin (360° Property Scanning)",
      "Concierge (Pre-arrival prep)",
      "4h Priority technical support",
      "Full rental management (on request)"
    ]
  }
};

const t = translations[currentLang] || translations.ro;
---

<section id="services" class="py-24 bg-white font-heading overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center mb-20">
      <h2 class="text-4xl font-black text-slate-900 sm:text-5xl uppercase tracking-tight">
        {t.title}
      </h2>
      <p class="mt-4 text-xl text-slate-600 max-w-2xl mx-auto">
        {t.subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      
      <div class="flex flex-col h-full bg-slate-50 p-8 rounded-[2rem] border border-slate-200 shadow-sm">
        <div class="mb-6">
          <h3 class="text-2xl font-black text-slate-800 text-left">PEARL 🐚</h3>
          <p class="text-slate-500 text-sm font-bold uppercase tracking-widest mt-1">Basic Care</p>
        </div>
        <div class="mb-8 font-black text-4xl text-slate-900 text-left">350€<span class="text-lg text-slate-400 font-normal">{t.perYear}</span></div>
        <ul class="space-y-4 mb-10 flex-grow text-slate-600 border-t border-slate-200 pt-6 text-left">
          {t.pearlFeatures.map(item => (
            <li class="flex items-start gap-2">
              <span class="text-blue-600 font-bold">✓</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
        <a href={`https://wa.me/34641477523?text=${encodeURIComponent(t.waPearl)}`} class="block text-center py-4 border-2 border-slate-900 font-bold rounded-xl hover:bg-slate-900 hover:text-white transition uppercase text-sm">
          {t.ctaPearl}
        </a>
      </div>

      <div class="flex flex-col h-full bg-white p-8 rounded-[2rem] border-4 border-blue-600 shadow-2xl relative md:-translate-y-4">
        <div class="absolute -top-5 left-1/2 -translate-x-1/2 bg-blue-600 text-white px-6 py-2 rounded-full text-[10px] font-black uppercase tracking-widest whitespace-nowrap">
          {t.mostPopular}
        </div>
        <div class="mb-6 pt-4">
          <h3 class="text-2xl font-black text-blue-600 text-left">SAPPHIRE 💙</h3>
          <p class="text-blue-400 text-sm font-bold uppercase tracking-widest mt-1">Standard Plus</p>
        </div>
        <div class="mb-8 font-black text-4xl text-slate-900 text-left">650€<span class="text-lg text-slate-400 font-normal">{t.perYear}</span></div>
        <ul class="space-y-4 mb-10 flex-grow text-slate-700 border-t border-blue-100 pt-6 text-left">
          <li class="font-bold text-blue-600 text-xs uppercase mb-2">{t.everythingIn} Pearl +</li>
          {t.sapphireFeatures.map(item => (
            <li class="flex items-start gap-2">
              <span class="text-blue-600 font-bold">✓</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
        <a href={`https://wa.me/34641477523?text=${encodeURIComponent(t.waSapphire)}`} class="block text-center py-4 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 transition shadow-lg uppercase text-sm">
          {t.ctaSapphire}
        </a>
      </div>

      <div class="flex flex-col h-full bg-slate-900 p-8 rounded-[2rem] border border-emerald-500 shadow-xl">
        <div class="mb-6">
          <h3 class="text-2xl font-black text-emerald-400 text-left">EMERALD 💚</h3>
          <p class="text-emerald-600 text-sm font-bold uppercase tracking-widest mt-1">VIP Security</p>
        </div>
        <div class="mb-8 font-black text-4xl text-white text-left">1500€<span class="text-lg text-slate-500 font-normal">{t.perYear}</span></div>
        <ul class="space-y-4 mb-10 flex-grow text-slate-300 border-t border-slate-800 pt-6 text-left">
          <li class="font-bold text-emerald-400 text-xs uppercase mb-2">{t.everythingIn} Sapphire +</li>
          {t.emeraldFeatures.map((item, index) => (
            <li class={`flex items-start gap-2 ${index === 0 ? 'text-white font-bold' : ''}`}>
              <span class="text-emerald-500 font-bold">{index === 0 ? '🛡️' : '✓'}</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
        <a href={`https://wa.me/34641477523?text=${encodeURIComponent(t.waEmerald)}`} class="block text-center py-4 bg-emerald-500 text-white font-bold rounded-xl hover:bg-emerald-600 transition shadow-lg uppercase text-sm">
          {t.ctaEmerald}
        </a>
      </div>

    </div>
  </div>
</section>
