---
import { brand } from '../config/brand';
import { client } from '../data/client';

// 1. Logica de detectare a limbii îmbunătățită
const url = new URL(Astro.request.url);
const pathname = url.pathname;

// Verificăm strict dacă URL-ul începe cu /en
const isEn = pathname.startsWith('/en/') || pathname === '/en';
const currentLang = isEn ? 'en' : 'ro';
const base = isEn ? '/en' : '';

const translations = {
  ro: {
    home: 'Acasă',
    about: 'Despre noi',
    services: 'Servicii',
    reviews: 'Recenzii',
    blog: 'Blog',
    contact: 'Contact',
    cta: 'Cere Ofertă'
  },
  en: {
    home: 'Home',
    about: 'About Us',
    services: 'Services',
    reviews: 'Reviews',
    blog: 'Blog',
    contact: 'Contact',
    cta: 'Get a Quote'
  }
};

const t = translations[currentLang];

const nav = [
  { label: t.home,     href: isEn ? '/en/' : '/' },
  { label: t.about,    href: `${base}/about` },
  { label: t.services, href: `${base}/services` },
  { label: t.reviews,  href: `${base}/reviews` },
  { label: t.blog,     href: `${base}/blog` },
  { label: t.contact,  href: `${base}/contact` },
];
---

<header class="sticky top-0 z-50 w-full border-b border-slate-200 bg-white/95 backdrop-blur-sm font-heading">
  <div class="mx-auto flex max-w-site items-center justify-between px-4 py-3 sm:px-6">
    
    <a href={isEn ? '/en/' : '/'} class="flex items-center gap-2 font-heading text-xl font-black uppercase tracking-tight text-blue-600 transition-opacity hover:opacity-80">
      <span>{brand.name}</span>
    </a>

    <nav class="hidden items-center gap-1 lg:flex">
      {nav.map(({ label, href }) => {
        // Logica de Active Page
        const isActive = pathname === href || (href !== '/' && href !== '/en/' && pathname.startsWith(href));
        return (
          <a
            href={href}
            class:list={[
              'rounded-md px-3 py-2 text-sm font-bold transition-all duration-200',
              isActive ? 'bg-blue-600 text-white shadow-md' : 'text-slate-600 hover:text-blue-600 hover:bg-slate-50',
            ]}
          >
            {label}
          </a>
        );
      })}
    </nav>

    <div class="hidden items-center gap-6 lg:flex">
      <div class="flex items-center bg-slate-100 p-1 rounded-full border border-slate-200">
        <a 
          href="/" 
          class:list={[
            "px-4 py-1.5 rounded-full text-[10px] font-black transition-all duration-300",
            !isEn ? "bg-blue-600 text-white shadow-lg" : "text-slate-500 hover:text-slate-800"
          ]}
        >
          RO
        </a>
        <a 
          href="/en/" 
          class:list={[
            "px-4 py-1.5 rounded-full text-[10px] font-black transition-all duration-300",
            isEn ? "bg-blue-600 text-white shadow-lg" : "text-slate-500 hover:text-slate-800"
          ]}
        >
          EN
        </a>
      </div>

      <a href={`tel:${client.phoneForTel}`} class="text-sm font-bold text-slate-700 hover:text-blue-600 transition-colors flex items-center gap-2">
        <svg class="size-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        {client.phoneFormatted}
      </a>
      
      <a href={isEn ? "/en/contact" : "/contact"} class="inline-flex h-10 items-center rounded-lg bg-slate-900 px-6 text-xs font-black uppercase text-white shadow-xl hover:bg-blue-600 transition-all duration-300">
        {t.cta}
      </a>
    </div>

    <div class="flex items-center gap-3 lg:hidden">
       <div class="flex items-center bg-slate-100 p-0.5 rounded-full border border-slate-200">
        <a href="/" class:list={["px-3 py-1 rounded-full text-[10px] font-black", !isEn ? "bg-blue-600 text-white shadow-sm" : "text-slate-500"]}>RO</a>
        <a href="/en/" class:list={["px-3 py-1 rounded-full text-[10px] font-black", isEn ? "bg-blue-600 text-white shadow-sm" : "text-slate-500"]}>EN</a>
      </div>

      <button id="menu-toggle" class="p-2 text-slate-900 bg-slate-50 rounded-lg">
        <svg id="menu-icon-open" class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16" stroke-width="2.5"/></svg>
        <svg id="menu-icon-close" class="hidden size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12" stroke-width="2.5"/></svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t border-slate-100 bg-white px-4 pb-12 pt-6 lg:hidden shadow-2xl">
    <nav class="flex flex-col gap-2">
      {nav.map(({ label, href }) => (
        <a href={href} class="rounded-xl px-4 py-4 text-lg font-black text-slate-900 hover:bg-blue-50 hover:text-blue-600 transition-colors border border-transparent hover:border-blue-100">{label}</a>
      ))}
      <a href={isEn ? "/en/contact" : "/contact"} class="mt-6 block w-full text-center rounded-2xl bg-blue-600 py-5 text-base font-black uppercase text-white shadow-lg">
        {t.cta}
      </a>
    </nav>
  </div>
</header>

<script is:inline>
  (function() {
    const btn = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');

    if (!btn || !menu || !iconOpen || !iconClose) return;

    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
      iconOpen.classList.toggle('hidden');
      iconClose.classList.toggle('hidden');
    });
  })();
</script>
