---
import { brand } from '../config/brand';
import { client } from '../data/client';

// 1. Metodă ultra-sigură de detectat limba din URL
const pathname = Astro.url.pathname;
const isEn = pathname.startsWith('/en/') || pathname === '/en';
const currentLang = isEn ? 'en' : 'ro';
const base = isEn ? '/en' : '';

const translations = {
  ro: {
    home: 'Acasă',
    about: 'Despre noi',
    services: 'Servicii',
    reviews: 'Recenzii',
    blog: 'Blog',
    contact: 'Contact',
    cta: 'Cere Ofertă'
  },
  en: {
    home: 'Home',
    about: 'About Us',
    services: 'Services',
    reviews: 'Reviews',
    blog: 'Blog',
    contact: 'Contact',
    cta: 'Get a Quote'
  }
};

const t = translations[currentLang];

const nav = [
  { label: t.home,     href: isEn ? '/en/' : '/' },
  { label: t.about,    href: `${base}/about` },
  { label: t.services, href: `${base}/services` },
  { label: t.reviews,  href: `${base}/reviews` },
  { label: t.blog,     href: `${base}/blog` },
  { label: t.contact,  href: `${base}/contact` },
];
---

<header
  class="sticky top-0 z-50 w-full border-b border-border bg-background/95 backdrop-blur-sm font-heading"
  transition:persist
>
  <div class="mx-auto flex max-w-site items-center justify-between px-4 py-3 sm:px-6">
    
    <a href={isEn ? '/en/' : '/'} class="flex items-center gap-2 font-heading text-xl font-bold uppercase tracking-wide text-primary transition-opacity hover:opacity-80">
      <span>{brand.name}</span>
    </a>

    <nav class="hidden items-center gap-1 lg:flex" aria-label="Navigare principală">
      {nav.map(({ label, href }) => {
        const isActive = pathname === href || (href !== '/' && href !== '/en/' && pathname.startsWith(href));
        return (
          <a
            href={href}
            class:list={[
              'rounded-md px-3 py-2 text-sm font-bold transition-colors',
              isActive ? 'bg-primary/10 text-primary' : 'text-slate-600 hover:text-primary',
            ]}
          >
            {label}
          </a>
        );
      })}
    </nav>

    <div class="hidden items-center gap-4 lg:flex">
      <div class="flex items-center bg-slate-100 p-1 rounded-lg border border-slate-200 mr-2">
        <a 
          href="/" 
          class:list={[
            "px-3 py-1 rounded-md text-[10px] font-black transition-all",
            !isEn ? "bg-white text-primary shadow-sm" : "text-slate-400 hover:text-slate-600"
          ]}
        >
          RO
        </a>
        <a 
          href="/en/" 
          class:list={[
            "px-3 py-1 rounded-md text-[10px] font-black transition-all",
            isEn ? "bg-white text-primary shadow-sm" : "text-slate-400 hover:text-slate-600"
          ]}
        >
          EN
        </a>
      </div>

      <a href={`tel:${client.phoneForTel}`} class="text-sm font-bold text-slate-700 hover:text-primary transition-colors flex items-center gap-2">
        <svg class="size-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        {client.phoneFormatted}
      </a>
      
      <a href={isEn ? "/en/contact" : "/contact"} class="inline-flex h-10 items-center rounded-md bg-blue-600 px-5 text-xs font-black uppercase text-white shadow-md hover:bg-blue-700 transition-all">
        {t.cta}
      </a>
    </div>

    <div class="flex items-center gap-3 lg:hidden">
       <div class="flex items-center bg-slate-100 p-0.5 rounded-md border border-slate-200">
        <a href="/" class:list={["px-2 py-1 rounded text-[10px] font-bold", !isEn ? "bg-white text-primary" : "text-slate-400"]}>RO</a>
        <a href="/en/" class:list={["px-2 py-1 rounded text-[10px] font-bold", isEn ? "bg-white text-primary" : "text-slate-400"]}>EN</a>
      </div>

      <button id="menu-toggle" class="text-slate-600">
        <svg id="menu-icon-open" class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16" stroke-width="2"/></svg>
        <svg id="menu-icon-close" class="hidden size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12" stroke-width="2"/></svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t bg-white px-4 pb-8 pt-4 lg:hidden">
    <nav class="flex flex-col gap-2">
      {nav.map(({ label, href }) => (
        <a href={href} class="rounded-lg px-4 py-3 text-base font-bold text-slate-700 hover:bg-slate-50">{label}</a>
      ))}
      <a href={isEn ? "/en/contact" : "/contact"} class="mt-4 block w-full text-center rounded-xl bg-blue-600 py-4 text-sm font-black uppercase text-white">
        {t.cta}
      </a>
    </nav>
  </div>
</header>

<script is:inline>
  (function() {
    const btn = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');

    if (!btn || !menu || !iconOpen || !iconClose) return;

    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
      iconOpen.classList.toggle('hidden');
      iconClose.classList.toggle('hidden');
    });
  })();
</script>
