---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { aboutImage as localAboutImage } from '../config/images';

// 1. Logica de detectare a limbii
const url = new URL(Astro.request.url);
const pathname = url.pathname;
const isEn = pathname.startsWith('/en/') || pathname === '/en';
const currentLang = isEn ? 'en' : 'ro';
const base = isEn ? '/en' : '';

const translations = {
  ro: {
    topper: 'Partenerul tău local',
    heading: 'Suntem ochii tăi în Spania, când tu nu poți fi aici',
    body: [
      'Știm ce înseamnă să ai o casă la mii de kilometri distanță. Micile defecțiuni, fenomenele meteo extreme sau riscul ocupării ilegale pot deveni surse constante de stres atunci când ești plecat.',
      'De aceea, am creat un serviciu bazat pe proximitate și încredere totală. Nu suntem o agenție gigant care vede doar un număr de contract, ci o echipă dedicată care îți tratează casa cu aceeași grijă cu care ne-o tratăm pe a noastră.',
    ],
    benefits: [
      'Verificări riguroase de siguranță la fiecare 48-72 de ore',
      'Rapoarte digitale pe WhatsApp (foto/video) după fiecare vizită',
      'Serviciu Pre-Arrival: Pregătim casa înainte să vii (curățenie, aerisire, cumpărături de bază)',
    ],
    ctaLabel: 'Află mai multe',
    imageAlt: 'Detalii chei casă vacanță Spania',
  },
  en: {
    topper: 'Your Local Partner',
    heading: 'We are your eyes in Spain, when you can’t be here',
    body: [
      'We know what it means to have a home thousands of miles away. Minor faults, extreme weather, or the risk of squatting can become constant sources of stress while you are away.',
      'That’s why we created a service based on proximity and total trust. We are not a giant agency that sees just a contract number, but a dedicated team that treats your home with the same care we treat our own.',
    ],
    benefits: [
      'Rigorous security checks every 48-72 hours',
      'Digital WhatsApp reports (photo/video) after each visit',
      'Pre-Arrival Service: We prepare the house before you arrive (cleaning, airing, basic shopping)',
    ],
    ctaLabel: 'Learn More',
    imageAlt: 'Holiday home keys details Spain',
  }
};

const t = translations[currentLang];

const PLACEHOLDER = 'https://images.unsplash.com/photo-1560184897-67f4a3f9a7fa?w=900&q=80';

interface Props {
  topper?: string;
  heading?: string;
  body?: string[];
  benefits?: string[];
  ctaLabel?: string;
  ctaHref?: string;
  imageSrc?: ImageMetadata | string;
  imageAlt?: string;
}

const {
  topper = t.topper,
  heading = t.heading,
  body = t.body,
  benefits = t.benefits,
  ctaLabel = t.ctaLabel,
  ctaHref = `${base}/about`,
  imageSrc = localAboutImage ?? PLACEHOLDER,
  imageAlt = t.imageAlt,
} = Astro.props;
---

<section class="py-24 bg-white font-heading">
  <div class="mx-auto grid max-w-site grid-cols-1 items-center gap-8 px-4 sm:px-6 lg:grid-cols-2 lg:gap-14">

    <div class="overflow-hidden rounded-2xl shadow-2xl transition-transform hover:scale-[1.01] duration-500">
      <Image
        src={imageSrc}
        alt={imageAlt}
        width={700}
        height={525}
        loading="lazy"
        decoding="async"
        class="size-full object-cover"
      />
    </div>

    <div class="space-y-5">
      <span class="text-topper font-bold uppercase tracking-widest text-blue-600">{topper}</span>
      <h2 class="font-heading text-4xl font-black uppercase text-slate-900 leading-tight">{heading}</h2>

      {body.map((paragraph) => (
        <p class="text-slate-600 leading-relaxed text-lg">{paragraph}</p>
      ))}

      <ul class="space-y-4 pt-2" role="list">
        {benefits.map((benefit) => (
          <li class="flex items-start gap-3">
            <div class="mt-1 flex size-6 shrink-0 items-center justify-center rounded-full bg-blue-50 text-blue-600">
                <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
            </div>
            <span class="text-slate-800 font-bold text-lg">{benefit}</span>
          </li>
        ))}
      </ul>

      <div class="pt-4">
        <a
          href={ctaHref}
          class="inline-flex min-h-[44px] items-center gap-2 rounded-xl bg-slate-900 px-8 py-4 text-base font-black uppercase text-white shadow-xl transition-all hover:bg-blue-600"
        >
          {ctaLabel}
          <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
