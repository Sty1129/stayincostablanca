---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { aboutImage as localAboutImage } from '../config/images';

// Am pus un placeholder care sugerează relaxarea și casa de vacanță
const PLACEHOLDER = 'https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=900&q=80';

interface Props {
  topper?: string;
  heading?: string;
  body?: string[];
  benefits?: string[];
  ctaLabel?: string;
  ctaHref?: string;
  imageSrc?: ImageMetadata | string;
  imageAlt?: string;
}

const {
  topper = 'Partenerul tău local',
  heading = 'Suntem ochii tăi în Spania, când tu nu poți fi aici',
  body = [
    'Știm ce înseamnă să ai o casă la mii de kilometri distanță. Micile defecțiuni, fenomenele meteo extreme sau riscul ocupării ilegale pot deveni surse constante de stres atunci când ești plecat.',
    'De aceea, am creat un serviciu bazat pe proximitate și încredere totală. Nu suntem o agenție gigant care vede doar un număr de contract, ci o echipă dedicată care îți tratează casa cu aceeași grijă cu care ne-o tratăm pe a noastră.',
  ],
  benefits = [
    'Verificări riguroase de siguranță la fiecare 48-72 de ore',
    'Rapoarte digitale pe WhatsApp (foto/video) după fiecare vizită',
    'Rețea proprie de instalatori și tehnicieni de încredere',
  ],
  ctaLabel = 'Află mai multe',
  ctaHref = '/about',
  imageSrc = localAboutImage ?? PLACEHOLDER,
  imageAlt = 'Vedere terasă mediteraneană în Costa Blanca',
} = Astro.props;
---

<section class="py-section bg-white">
  <div class="mx-auto grid max-w-site grid-cols-1 items-center gap-8 px-4 sm:px-6 lg:grid-cols-2 lg:gap-14">

    <div class="overflow-hidden rounded-2xl shadow-2xl transition-transform hover:scale-[1.01] duration-500">
      <Image
        src={imageSrc}
        alt={imageAlt}
        width={700}
        height={525}
        loading="lazy"
        decoding="async"
        class="size-full object-cover"
      />
    </div>

    <div class="space-y-5">
      <span class="text-topper font-bold uppercase tracking-widest text-accent">{topper}</span>
      <h2 class="font-heading text-h2 font-bold uppercase text-text leading-tight">{heading}</h2>

      {body.map((paragraph) => (
        <p class="text-text-muted leading-relaxed text-lg">{paragraph}</p>
      ))}

      <ul class="space-y-4 pt-2" role="list">
        {benefits.map((benefit) => (
          <li class="flex items-start gap-3">
            <div class="mt-1 flex size-6 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
                <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
            </div>
            <span class="text-text font-medium text-lg">{benefit}</span>
          </li>
        ))}
      </ul>

      <div class="pt-4">
        <a
          href={ctaHref}
          class="inline-flex min-h-[44px] items-center gap-2 rounded-md bg-slate-900 px-8 py-4 text-base font-bold text-white shadow-md transition-all hover:bg-slate-800 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        >
          {ctaLabel}
          <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
