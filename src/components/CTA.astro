---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { aboutImage as localAboutImage } from '../config/images';
import { client } from '../data/client';

// 1. Logica de detectare a limbii
const url = new URL(Astro.request.url);
const pathname = url.pathname;
const isEn = pathname.startsWith('/en/') || pathname === '/en';
const currentLang = isEn ? 'en' : 'ro';

const translations = {
  ro: {
    topper: 'Partenerul tău local',
    heading: 'Suntem ochii tăi în Spania, când tu nu poți fi aici',
    body: [
      'Știm ce înseamnă să ai o casă la mii de kilometri distanță. Micile defecțiuni, fenomenele meteo extreme sau riscul ocupării ilegale pot deveni surse constante de stres atunci când ești plecat.',
      'De aceea, am creat un serviciu bazat pe proximitate și încredere totală. Nu suntem o agenție gigant, ci o echipă dedicată care îți tratează casa cu aceeași grijă cu care ne-o tratăm pe a noastră.',
    ],
    benefits: [
      'Verificări riguroase de siguranță la fiecare 48-72 de ore',
      'Rapoarte digitale pe WhatsApp (foto/video) după fiecare vizită',
      'Serviciu Pre-Arrival: Pregătim casa înainte să vii',
    ],
    ctaLabel: 'Solicită Ofertă pe WhatsApp',
    waMessage: 'Salut Stelian! Vreau o ofertă pentru administrarea casei mele.',
    imageAlt: 'Detalii chei casă vacanță Spania',
  },
  en: {
    topper: 'Your Local Partner',
    heading: 'We are your eyes in Spain, when you can’t be here',
    body: [
      'We know what it means to have a home thousands of miles away. Minor faults, extreme weather, or the risk of squatting can become constant sources of stress while you are away.',
      'That’s why we created a service based on proximity and total trust. We are not a giant agency, but a dedicated team that treats your home with the same care as our own.',
    ],
    benefits: [
      'Rigorous security checks every 48-72 hours',
      'Digital WhatsApp reports (photo/video) after each visit',
      'Pre-Arrival Service: We prepare the house before you arrive',
    ],
    ctaLabel: 'Get a Quote on WhatsApp',
    waMessage: 'Hi Stelian! I would like to get a quote for my property management.',
    imageAlt: 'Holiday home keys details Spain',
  }
};

const t = translations[currentLang];

// Link WhatsApp Dinamic
const waLink = `https://wa.me/${client.phoneForTel.replace(/-/g, '')}?text=${encodeURIComponent(t.waMessage)}`;

const PLACEHOLDER = 'https://images.unsplash.com/photo-1560184897-67f4a3f9a7fa?w=900&q=80';

interface Props {
  topper?: string;
  heading?: string;
  body?: string[];
  benefits?: string[];
  ctaLabel?: string;
  imageSrc?: ImageMetadata | string;
  imageAlt?: string;
}

const {
  topper = t.topper,
  heading = t.heading,
  body = t.body,
  benefits = t.benefits,
  ctaLabel = t.ctaLabel,
  imageSrc = localAboutImage ?? PLACEHOLDER,
  imageAlt = t.imageAlt,
} = Astro.props;
---

<section class="py-24 bg-slate-50 font-heading">
  <div class="mx-auto grid max-w-site grid-cols-1 items-center gap-12 px-4 sm:px-6 lg:grid-cols-2">
    
    <div class="order-2 lg:order-2 overflow-hidden rounded-3xl shadow-2xl">
      <Image
        src={imageSrc}
        alt={imageAlt}
        width={700}
        height={500}
        class="size-full object-cover transition-transform duration-700 hover:scale-105"
      />
    </div>

    <div class="order-1 lg:order-1 space-y-6">
      <span class="inline-block px-4 py-1.5 bg-blue-100 text-blue-700 rounded-full text-xs font-black uppercase tracking-widest">
        {topper}
      </span>
      
      <h2 class="text-3xl md:text-5xl font-black text-slate-900 uppercase leading-tight">
        {heading}
      </h2>

      <div class="space-y-4">
        {body.map((p) => (
          <p class="text-slate-600 text-lg leading-relaxed">{p}</p>
        ))}
      </div>

      <ul class="grid gap-3 pt-4">
        {benefits.map((b) => (
          <li class="flex items-center gap-3 text-slate-800 font-bold">
            <span class="flex size-6 items-center justify-center rounded-full bg-blue-600 text-white">
              <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            </span>
            {b}
          </li>
        ))}
      </ul>

      <div class="pt-6">
        <a
          href={waLink}
          target="_blank"
          class="inline-flex items-center gap-3 bg-blue-600 hover:bg-blue-700 text-white px-8 py-5 rounded-2xl font-black uppercase text-sm tracking-widest transition-all shadow-xl hover:scale-105"
        >
          <svg class="size-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
          {t.ctaLabel}
        </a>
      </div>
    </div>

  </div>
</section>
