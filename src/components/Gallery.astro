---
import { Image } from "astro:assets";

// Imagini alese special pentru Property Management & Costa Blanca
const images = [
  {
    src: 'https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=800&q=80',
    alt: 'Vile premium sub supravegherea noastră',
  },
  {
    src: 'https://images.unsplash.com/photo-1560184897-67f4a3f9a7fa?w=800&q=80',
    alt: 'Verificări riguroase ale interiorului',
  },
  {
    src: 'https://images.unsplash.com/photo-1519449556851-5720b33024e7?w=800&q=80',
    alt: 'Locații de vis în Torrevieja și Orihuela',
  },
  {
    src: 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=800&q=80',
    alt: 'Administrare proprietăți moderne',
  },
  {
    src: 'https://images.unsplash.com/photo-1493809842364-78817add7ffb?w=800&q=80',
    alt: 'Key Holding și acces securizat',
  },
  {
    src: 'https://images.unsplash.com/photo-1613490493576-7fde63acd811?w=800&q=80',
    alt: 'Întreținere terase și zone comune',
  },
];

interface Props {
  topper?: string;
  heading?: string;
  description?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  topper = "Standard de Calitate",
  heading = "Proprietăți în Siguranță",
  description = "O privire asupra atenției la detalii pe care o oferim fiecărei case din Torrevieja și Orihuela Costa.",
  ctaLabel = "Vezi Serviciile Noastre",
  ctaHref = "/services",
} = Astro.props;
---

<section class="py-section font-heading">
  <div class="mx-auto max-w-site px-4 sm:px-6">
    <div class="mx-auto mb-10 max-w-2xl text-center lg:mb-14">
      <span class="text-topper font-bold uppercase tracking-widest text-accent">{topper}</span>
      <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">
        {heading}
      </h2>
      <p class="mt-3 text-text-muted leading-relaxed text-lg">{description}</p>
    </div>

    <div class="grid grid-cols-2 gap-3 sm:gap-4 lg:grid-cols-3">
      {
        images.map(({ src, alt }) => (
          <div
            class="group relative overflow-hidden rounded-2xl aspect-4/3 bg-surface shadow-md"
            data-gallery-item
          >
            <div
              class="absolute inset-0 animate-pulse bg-linear-to-r from-surface via-border to-surface"
              aria-hidden="true"
              data-skeleton
            />

            <img
              src={src}
              alt={alt}
              loading="lazy"
              decoding="async"
              class="relative size-full object-cover opacity-0 transition-all duration-500 group-hover:scale-110"
              data-gallery-img
            />

            <div class="absolute inset-0 flex items-end bg-linear-to-t from-black/70 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100">
              <p class="p-3 text-sm font-medium text-white sm:p-4">{alt}</p>
            </div>
          </div>
        ))
      }
    </div>

    {
      ctaLabel && (
        <div class="mt-10 text-center">
          <a
            href={ctaHref}
            class="inline-flex min-h-[44px] items-center gap-2 rounded-md border-2 border-primary px-8 py-3 text-base font-bold text-primary transition-all hover:bg-primary hover:text-white"
          >
            {ctaLabel}
            <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      )
    }
  </div>
</section>

<script>
  function initGallery() {
    document.querySelectorAll<HTMLElement>("[data-gallery-item]").forEach((item) => {
      const img = item.querySelector<HTMLImageElement>("[data-gallery-img]");
      const skeleton = item.querySelector<HTMLElement>("[data-skeleton]");
      if (!img || !skeleton) return;

      function onLoad() {
        img!.classList.remove("opacity-0");
        skeleton!.remove();
      }

      if (img.complete) {
        onLoad();
      } else {
        img.addEventListener("load", onLoad, { once: true });
      }
    });
  }

  initGallery();
  document.addEventListener("astro:after-swap", initGallery);
</script>
