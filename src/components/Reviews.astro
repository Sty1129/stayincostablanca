---
interface Review {
  quote: string;
  name: string;
  location: string;
  rating?: number;
}

interface Props {
  topper?: string;
  heading?: string;
  reviews?: Review[];
}

const {
  topper = 'Opinii Clienți',
  heading = 'Ce spun proprietarii care au ales liniștea',
  reviews = [
    { 
      quote: 'Cea mai mare teamă a noastră era legată de ocupările ilegale cât suntem plecați în România. De când Stelian se ocupă de casă, primim rapoarte video săptămânale și dormim mult mai liniștiți. Recomand!', 
      name: 'Andrei V.', 
      location: 'București, RO', 
      rating: 5 
    },
    { 
      quote: 'După furtuna DANA de anul trecut, am fost panicați. Stelian a mers la proprietate imediat, a verificat terasa și scurgerile și ne-a trimis poze că totul e în regulă. Profesionalism rar întâlnit.', 
      name: 'Maria G.', 
      location: 'Cluj-Napoca, RO', 
      rating: 5 
    },
    { 
      quote: 'Serviciul de pre-arrival este fantastic. Am ajuns la miezul nopții cu copiii și am găsit casa aerisită, răcoroasă și frigiderul plin cu tot ce aveam nevoie pentru micul dejun. 5 stele!', 
      name: 'Robert D.', 
      location: 'London, UK', 
      rating: 5 
    },
  ],
} = Astro.props;
---

<section class="bg-surface py-section font-heading">
  <div class="mx-auto max-w-site px-4 sm:px-6">
    <div class="mx-auto mb-10 max-w-2xl text-center lg:mb-14">
      <span class="text-topper font-bold uppercase tracking-widest text-accent">{topper}</span>
      <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">{heading}</h2>
    </div>

    <ul class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3" role="list">
      {reviews.map(({ quote, name, location, rating = 5 }) => (
        <li class="flex flex-col rounded-2xl border border-border bg-background p-8 shadow-sm transition-all hover:shadow-md">
          <div class="mb-4 flex gap-0.5" aria-label={`Rated ${rating} out of 5 stars`}>
            {Array.from({ length: 5 }).map((_, i) => (
              <svg
                class:list={['size-5', i < rating ? 'text-accent' : 'text-border']}
                fill="currentColor"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <blockquote class="flex-1 text-text-muted leading-relaxed italic text-lg">
            &ldquo;{quote}&rdquo;
          </blockquote>

          <div class="mt-6 border-t border-border pt-6 flex items-center gap-3">
            <div class="size-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold">
              {name.charAt(0)}
            </div>
            <div>
              <p class="font-bold text-text">{name}</p>
              <p class="text-sm text-text-muted">{location}</p>
            </div>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
