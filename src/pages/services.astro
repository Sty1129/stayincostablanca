---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Banner from '../components/Banner.astro';
import CTA from '../components/CTA.astro';
import { client } from '../data/client'; // Folosim client din data client pentru date

const services = [
  {
    title: 'Key Holding & Control 🔑',
    description: 'Păstrare securizată a cheilor și vizite periodice riguroase. Verificăm instalațiile, aerisim locuința și ne asigurăm că totul este în ordine după fenomene meteo extreme.',
  },
  {
    title: 'Management Administrativ 📑',
    description: 'Scapă de birocrația spaniolă. Gestionăm plata taxelor (IBI, Suma), monitorizăm facturile de utilități pentru a preveni supraconsumul și ținem legătura cu comunitatea de vecini.',
  },
  {
    title: 'Protecție Anti-Okupas 🛡️',
    description: 'Protocol "First Responder" cu intervenție rapidă în fereastra critică de 48h. Suntem contactul nr. 1 pentru firma de securitate, oferind acces Poliției pentru evacuare legală imediată.',
  },
  {
    title: 'Car Care & Valet 🚗',
    description: 'Mașina ta de Spania, gata de drum. Verificăm bateria, presiunea în roți și valabilitatea ITV. Oferim și serviciu de valet/transfer de la aeroport cu mașina proprietarului.',
  },
  {
    title: 'Digital Twin Inventory 📸',
    description: 'Scanare 360° și inventar digital certificat. O dovadă incontestabilă a stării bunurilor tale, utilă pentru asigurări sau în cazul închirierii pe termen scurt.',
  },
  {
    title: 'Pre-Arrival Concierge 🛒',
    description: 'Pregătim casa pentru sosirea ta: pornim climatizarea, verificăm apa caldă și putem face cumpărăturile de bază pentru ca tu să te bucuri de vacanță din prima secundă.',
  },
];

// Iconițe actualizate (SVG-uri pentru Property Management)
const icons = [
  '<path d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />', // Key
  '<path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />', // Admin
  '<path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />', // Shield
  '<path d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />', // Car/Transfer
  '<path d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" /><path d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />', // Camera
  '<path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />', // Grocery
];
---

<BaseLayout title="Servicii" description={`Explorează serviciile premium oferite de ${client.name} în Torrevieja și Orihuela Costa. Administrare completă pentru liniștea ta.`}>
  <Header slot="header" />

  <Banner title="Serviciile Noastre" />

  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center lg:mb-14">
        <h2 class="text-3xl font-bold text-slate-900 sm:text-4xl uppercase">Expertiză Locală, Standarde Internaționale</h2>
        <p class="mt-4 text-lg text-slate-600">
          Nu suntem doar o agenție de chei. Suntem partenerul tău de încredere în Spania, asigurându-ne că proprietatea ta este protejată, administrată corect și gata de oaspeți.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {services.map((service, i) => (
          <div class="flex flex-col gap-5 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex size-14 shrink-0 items-center justify-center rounded-xl bg-blue-600 text-white shadow-lg shadow-blue-200">
              <svg class="size-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" set:html={icons[i]} />
            </div>
            <div>
              <h3 class="text-xl font-bold text-slate-900">{service.title}</h3>
              <p class="mt-3 text-slate-600 leading-relaxed">{service.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
