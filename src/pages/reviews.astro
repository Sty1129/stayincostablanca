---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Banner from '../components/Banner.astro';
import CTA from '../components/CTA.astro';
import { brand } from '../config/brand';
import { client } from '../data/client';

const reviews = [
  { 
    quote: 'Serviciu impecabil. Stelian ne-a trimis poze și video după fiecare vizită, ceea ce ne oferă o liniște imensă știind că locuința din Torrevieja este pe mâini bune.', 
    name: 'Mihai G.', 
    location: 'București (Proprietar în Torrevieja)', 
    rating: 5 
  },
  { 
    quote: 'Am apelat la ei pentru serviciul de Key Holding și am fost impresionați de profesionalism. Totul a fost pregătit perfect pentru sosirea noastră în vacanță.', 
    name: 'Elena D.', 
    location: 'Cluj-Napoca (Proprietar în Orihuela Costa)', 
    rating: 5 
  },
  { 
    quote: 'Promptitudine maximă la o urgență cu o țeavă spartă în lipsa noastră. Au rezolvat problema înainte să devină un dezastru. Recomand cu încredere!', 
    name: 'Andrei S.', 
    location: 'Timișoara (Proprietar în La Zenia)', 
    rating: 5 
  },
  { 
    quote: 'Prețuri corecte și comunicare excelentă pe WhatsApp. Este esențial să ai pe cineva local de încredere când ești în altă țară.', 
    name: 'Carmen P.', 
    location: 'Brașov (Proprietar în Punta Prima)', 
    rating: 5 
  },
  { 
    quote: 'Monitorizarea împotriva "Okupas" este motivul pentru care dormim liniștiți noaptea. Un serviciu obligatoriu pentru orice proprietar din Spania.', 
    name: 'Robert L.', 
    location: 'Sibiu (Proprietar în Playa Flamenca)', 
    rating: 5 
  },
  { 
    quote: 'Stelian este extrem de serios. Ne-a ajutat chiar și cu mici reparații pe care nu aveam cum să le gestionăm de la distanță. Nota 10!', 
    name: 'Simona T.', 
    location: 'Iași (Proprietar în Torrevieja)', 
    rating: 5 
  },
];
---

<BaseLayout
  title="Recenzii Clienți"
  description={`Citește testimonialele clienților noștri. Vezi de ce proprietarii de case din Costa Blanca aleg ${brand.name} pentru administrarea proprietăților.`}
  schema={{
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    name: client.name,
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '5',
      reviewCount: String(reviews.length),
      bestRating: '5',
    },
  }}
>
  <Header slot="header" />

  <Banner title="Recenzii Clienți" />

  <section class="py-section font-heading">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center lg:mb-14">
        <h2 class="font-heading text-h2 font-bold uppercase text-text">Ce spun proprietarii</h2>
        <p class="mt-3 text-text-muted leading-relaxed">
          Nu ne crede pe cuvânt — iată experiențele oamenilor pe care îi ajutăm să își protejeze investițiile din Spania.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {reviews.map(({ quote, name, location, rating = 5 }) => (
          <div class="flex flex-col rounded-2xl border border-border bg-background p-6 shadow-sm transition-all hover:shadow-md">
            <div class="mb-4 flex gap-0.5" aria-label={`Evaluat cu ${rating} din 5 stele`}>
              {Array.from({ length: 5 }).map((_, i) => (
                <svg
                  class:list={['size-5', i < rating ? 'text-accent' : 'text-border']}
                  fill="currentColor"
                  viewBox="0 0 20 20"
                  aria-hidden="true"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="flex-1 text-text-muted leading-relaxed italic">
              &ldquo;{quote}&rdquo;
            </blockquote>
            <div class="mt-6 border-t border-border pt-4">
              <p class="font-bold text-text uppercase tracking-tight">{name}</p>
              <p class="text-xs font-medium text-accent uppercase mt-1">{location}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
