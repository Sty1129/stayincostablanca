---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Banner from '../components/Banner.astro';
import CTA from '../components/CTA.astro';
import { brand } from '../config/brand';
import { client } from '../data/client';

const team = [
  { 
    name: 'Stelian', 
    role: 'Fondator & Key Manager', 
    image: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400&q=80' 
  },
  { 
    name: 'Echipa Locală', 
    role: 'Mentenanță & Suport', 
    image: 'https://images.unsplash.com/photo-1582213726895-42ac826c5bd1?w=400&q=80' 
  },
];
---

<BaseLayout 
  title="Despre Noi" 
  description={`Află povestea ${brand.name} — partenerul tău de încredere în Costa Blanca.`}
>
  <Header slot="header" />
  <Banner title="Despre Noi" />

  <section class="py-16 sm:py-24 font-heading">
    <div class="mx-auto grid max-w-site grid-cols-1 items-center gap-12 px-4 sm:px-6 lg:grid-cols-2">
      <div class="overflow-hidden rounded-2xl shadow-xl">
        <img
          src="https://images.unsplash.com/photo-1554435493-93422e8220c8?w=800&q=80"
          alt="Proprietate monitorizată"
          class="size-full object-cover"
        />
      </div>
      <div class="space-y-6">
        <h2 class="text-3xl font-bold uppercase text-text sm:text-4xl">Liniștea ta, misiunea noastră</h2>
        <p class="text-lg text-text-muted leading-relaxed">
          {brand.name} a fost creat pentru a oferi proprietarilor de case din zona Torrevieja un serviciu de administrare personalizat și extrem de sigur.
        </p>
        <p class="text-lg text-text-muted leading-relaxed">
          Suntem aici pentru a ne asigura că locuința ta din Spania este protejată, verificată periodic și pregătită oricând pentru sosirea ta.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-surface py-16 sm:py-24 font-heading">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <h2 class="mb-12 text-center text-3xl font-bold uppercase text-text">Echipa Noastră</h2>
      <div class="flex flex-wrap justify-center gap-8">
        {team.map((member) => (
          <div class="w-full max-w-sm overflow-hidden rounded-2xl bg-white shadow-lg text-center">
            <img src={member.image} alt={member.name} class="aspect-square w-full object-cover" />
            <div class="p-6">
              <h3 class="text-xl font-bold text-text uppercase">{member.name}</h3>
              <p class="text-accent font-medium uppercase text-xs tracking-widest mt-1">{member.role}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA />
  <Footer slot="footer" />
</BaseLayout>
