---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { brand } from '../../config/brand';
import { client } from '../../data/client';
---

<BaseLayout 
  title="Mesaj Trimis" 
  description="Mulțumim pentru mesaj! Te vom contacta în cel mai scurt timp."
>
  <Header slot="header" />

  <section class="py-24 sm:py-32 flex min-h-[60vh] items-center justify-center font-heading">
    <div class="mx-auto max-w-2xl px-4 text-center sm:px-6">
      
      <div class="mx-auto mb-8 flex size-20 items-center justify-center rounded-full bg-green-100 text-green-600">
        <svg class="size-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="font-heading text-h2 font-bold uppercase text-text leading-tight">
        Mesaj Trimis cu Succes!
      </h1>
      
      <p class="mt-6 text-lg text-text-muted leading-relaxed">
        Mulțumim pentru încredere. Am primit solicitarea ta, iar <strong>Stelian</strong> te va contacta în cel mai scurt timp pentru a discuta despre proprietatea ta.
      </p>

      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="/"
          class="inline-flex min-h-[44px] items-center justify-center rounded-md bg-primary px-10 py-3 text-base font-bold text-primary-fg shadow-lg transition-all hover:opacity-90 active:scale-95"
        >
          Înapoi la Acasă
        </a>
        
        <a
          href={`https://wa.me/${client.phoneForTel}`}
          target="_blank"
          class="inline-flex min-h-[44px] items-center justify-center gap-2 rounded-md border-2 border-border px-8 py-3 text-base font-bold text-text transition-colors hover:bg-surface"
        >
          Scrie-ne pe WhatsApp
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
