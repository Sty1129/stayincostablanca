---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import { brand } from '../../config/brand';
import { client } from '../../data/client';
---

<BaseLayout 
  title="Contact" 
  description={`Ia legătura cu echipa ${brand.name}. Cere o ofertă pentru administrarea proprietății tale din Costa Blanca.`}
>
  <Header slot="header" />

  <Banner title="Contactează-ne" />

  <section class="py-section font-heading">
    <div class="mx-auto grid max-w-site grid-cols-1 gap-10 px-4 sm:px-6 lg:grid-cols-5 lg:gap-14">

      <div class="lg:col-span-3">
        <h2 class="font-heading text-h2 font-bold uppercase text-text">Trimite-ne un mesaj</h2>
        <p class="mt-2 mb-8 text-text-muted">
          Completează datele de mai jos și Stelian îți va răspunde în cel mai scurt timp (de obicei sub 24h).
        </p>

        <form
          action="https://formspree.io/f/xjgjyjdk"
          method="POST"
          class="flex flex-col gap-5"
        >
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <label class="flex flex-col gap-1.5">
              <span class="text-sm font-medium text-text">Nume Complet <span class="text-accent">*</span></span>
              <input
                type="text"
                name="Nume"
                required
                placeholder="Ex: Ion Popescu"
                class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
              />
            </label>

            <label class="flex flex-col gap-1.5">
              <span class="text-sm font-medium text-text">Email <span class="text-accent">*</span></span>
              <input
                type="email"
                name="Email"
                required
                placeholder="email@exemplu.com"
                class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
              />
            </label>
          </div>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Telefon / WhatsApp</span>
            <input
              type="tel"
              name="Telefon"
              placeholder="+40 7xx xxx xxx"
              class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Mesaj <span class="text-accent">*</span></span>
            <textarea
              name="Mesaj"
              rows="5"
              required
              placeholder="Cu ce te putem ajuta?"
              class="min-h-[120px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 resize-y"
            ></textarea>
          </label>

          <input type="hidden" name="_next" value="https://stayincostablanca.com/contact/success">
          
          <button
            type="submit"
            class="mt-2 inline-flex min-h-[44px] cursor-pointer items-center justify-center self-start rounded-md bg-primary px-10 py-4 text-base font-bold text-primary-fg shadow-lg transition-all hover:scale-[1.02] active:scale-95"
          >
            Trimite Mesajul
          </button>
        </form>
      </div>

      <aside class="space-y-8 lg:col-span-2">
        <div class="rounded-2xl bg-surface p-8 border border-border shadow-sm">
          <h3 class="font-heading text-lg font-bold text-text uppercase tracking-wide mb-4">Contact Rapid</h3>
          
          <div class="space-y-6">
            <div>
              <p class="text-xs font-bold uppercase text-accent tracking-tighter">Sună sau scrie pe WhatsApp</p>
              <a href={`tel:${client.phoneForTel}`} class="mt-1 block text-primary font-bold text-xl transition-colors hover:text-accent">
                {client.phoneFormatted}
              </a>
            </div>

            <div>
              <p class="text-xs font-bold uppercase text-accent tracking-tighter">Email direct</p>
              <a href={`mailto:${client.email}`} class="mt-1 block text-primary font-medium transition-colors hover:text-accent">
                {client.email}
              </a>
            </div>

            <div>
              <p class="text-xs font-bold uppercase text-accent tracking-tighter">Zonă Acoperită</p>
              <p class="mt-1 text-text-muted leading-relaxed font-medium">
                Torrevieja, Orihuela Costa<br />
                și împrejurimi (Alicante)
              </p>
            </div>
          </div>
        </div>

        <div class="p-8">
           <h3 class="font-heading text-sm font-bold text-text uppercase mb-2">Disponibilitate</h3>
           <p class="text-sm text-text-muted">
             Răspundem la mesaje de Luni până Vineri între 09:00 - 18:00. <br><br>
             <span class="text-accent font-bold italic">Pentru urgențe (Okupas), ne poți contacta 24/7 pe WhatsApp.</span>
           </p>
        </div>
      </aside>

    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
