---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import { brand } from '../../config/brand';
import { client } from '../../data/client';
---

<BaseLayout 
  title="Contact" 
  description={`Ia legătura cu echipa ${brand.name}. Cere o ofertă pentru administrarea proprietății tale din Costa Blanca.`}
>
  <Header slot="header" />

  <Banner title="Contactează-ne" />

  <section class="py-section font-heading">
    <div class="mx-auto grid max-w-site grid-cols-1 gap-10 px-4 sm:px-6 lg:grid-cols-5 lg:gap-14">

      <div class="lg:col-span-3">
        <h2 class="font-heading text-h2 font-bold uppercase text-text">Trimite-ne un mesaj</h2>
        <p class="mt-2 mb-8 text-text-muted">
          Completează datele de mai jos și Stelian îți va răspunde în cel mai scurt timp posibil.
        </p>

        <form
          id="contact-form"
          action="https://formspree.io/f/xjgjyjdk"
          method="POST"
          class="flex flex-col gap-5"
        >
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <label class="flex flex-col gap-1.5">
              <span class="text-sm font-medium text-text">Nume Complet <span class="text-accent">*</span></span>
              <input
                type="text"
                name="Nume"
                required
                placeholder="Ex: Ion Popescu"
                class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
              />
            </label>

            <label class="flex flex-col gap-1.5">
              <span class="text-sm font-medium text-text">Email <span class="text-accent">*</span></span>
              <input
                type="email"
                name="Email"
                required
                placeholder="email@exemplu.com"
                class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
              />
            </label>
          </div>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Telefon / WhatsApp</span>
            <input
              type="tel"
              name="Telefon"
              placeholder="+40 7xx xxx xxx"
              class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Mesaj <span class="text-accent">*</span></span>
            <textarea
              name="Mesaj"
              rows="5"
              required
              placeholder="Spune-ne câteva detalii despre proprietatea ta..."
              class="min-h-[120px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 resize-y"
            ></textarea>
          </label>

          <button
            id="submit-btn"
            type="submit"
            class="mt-2 inline-flex min-h-[48px] cursor-pointer items-center justify-center self-start rounded-md bg-primary px-10 py-4 text-base font-bold text-primary-fg shadow-lg transition-all hover:scale-[1.02] active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Trimite Mesajul
          </button>
          
          <p id="form-status" class="hidden text-sm font-medium"></p>
        </form>
      </div>

      <aside class="space-y-8 lg:col-span-2">
        <div class="rounded-2xl bg-surface p-8 border border-border shadow-sm">
          <h3 class="font-heading text-lg font-bold text-text uppercase tracking-wide mb-6">Contact Rapid</h3>
          
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="bg-primary/10 p-2 rounded-lg text-primary">
                <svg class="size-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              </div>
              <div>
                <p class="text-[10px] font-bold uppercase text-accent tracking-widest">WhatsApp / Telefon</p>
                <a href={`tel:${client.phoneForTel}`} class="block text-primary font-bold text-lg hover:text-accent transition-colors">
                  {client.phoneFormatted}
                </a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="bg-primary/10 p-2 rounded-lg text-primary">
                <svg class="size-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 0-2-2H5a2 2 0 0-2 2v10a2 2 0 002 2z" /></svg>
              </div>
              <div>
                <p class="text-[10px] font-bold uppercase text-accent tracking-widest">Email</p>
                <a href={`mailto:${client.email}`} class="block text-primary font-medium hover:text-accent transition-colors">
                  {client.email}
                </a>
              </div>
            </div>

            <div class="flex items-start gap-4 border-t border-border pt-6">
               <div class="bg-accent/10 p-2 rounded-lg text-accent">
                <svg class="size-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              </div>
              <div>
                <p class="text-[10px] font-bold uppercase text-accent tracking-widest">Zonă Acoperită</p>
                <p class="text-text-muted text-sm font-medium mt-1">Torrevieja & Orihuela Costa</p>
              </div>
            </div>
          </div>
        </div>

        <div class="p-4 bg-accent/5 rounded-
