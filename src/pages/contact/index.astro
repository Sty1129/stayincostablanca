---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import { brand } from '../../config/brand';
import { client } from '../../data/client';
---

<BaseLayout 
  title="Contact" 
  description={`Contactează echipa ${brand.name} pentru administrare proprietăți.`}
>
  <Header slot="header" />
  <Banner title="Contactează-ne" />

  <section class="py-section font-heading">
    <div class="mx-auto grid max-w-site grid-cols-1 gap-10 px-4 sm:px-6 lg:grid-cols-5 lg:gap-14">
      
      <div class="lg:col-span-3">
        <h2 class="font-heading text-h2 font-bold uppercase text-text">Trimite-ne un mesaj</h2>
        <p class="mt-2 mb-8 text-text-muted">Îți vom răspunde în cel mai scurt timp posibil.</p>

        <form
          id="contact-form"
          class="flex flex-col gap-5"
        >
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <label class="flex flex-col gap-1.5">
              <span class="text-sm font-medium text-text">Nume Complet *</span>
              <input type="text" name="name" required class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 outline-none focus:border-primary" />
            </label>
            <label class="flex flex-col gap-1.5">
              <span class="text-sm font-medium text-text">Email *</span>
              <input type="email" name="email" required class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 outline-none focus:border-primary" />
            </label>
          </div>
          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Mesaj *</span>
            <textarea name="message" rows="5" required class="min-h-[120px] rounded-md border border-border bg-background px-4 py-2.5 resize-y outline-none focus:border-primary"></textarea>
          </label>

          <button
            id="submit-btn"
            type="submit"
            class="inline-flex min-h-[48px] items-center justify-center rounded-md bg-primary px-10 py-4 text-base font-bold text-primary-fg shadow-lg transition-all hover:opacity-90 disabled:opacity-50"
          >
            Trimite Mesajul
          </button>
          <p id="form-status" class="hidden text-sm font-bold mt-2"></p>
        </div>

        <aside class="lg:col-span-2 space-y-6">
          <div class="rounded-2xl bg-surface p-8 border border-border">
            <h3 class="font-bold uppercase mb-4 text-text">Contact Rapid</h3>
            <p class="text-sm text-primary font-bold">{client.phoneFormatted}</p>
            <p class="text-sm text-text-muted">{client.email}</p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script is:inline>
  // Punem ID-ul tau direct in JS
  const FORMSPREE_URL = "https://formspree.io/f/xjgjyjdk";

  function initForm() {
    const form = document.getElementById('contact-form');
    const btn = document.getElementById('submit-btn');
    const status = document.getElementById('form-status');

    if (!form || form.dataset.listener === "true") return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      e.stopPropagation(); // Oprim orice altă acțiune a browserului

      btn.disabled = true;
      btn.innerText = 'Se trimite...';

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      try {
        const response = await fetch(FORMSPREE_URL, {
          method: 'POST',
          body: JSON.stringify(data),
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          }
        });

        if (response.ok) {
          // REDIRECT FORȚAT
          window.location.replace('/contact/success');
        } else {
          alert('A apărut o problemă. Te rugăm să încerci din nou.');
          btn.disabled = false;
          btn.innerText = 'Trimite Mesajul';
        }
      } catch (error) {
        alert('Eroare de rețea. Verifică conexiunea.');
        btn.disabled = false;
        btn.innerText = 'Trimite Mesajul';
      }
    });

    form.dataset.listener = "true";
  }

  // Pornim la prima încărcare
  initForm();
  
  // Repornim dacă Astro schimbă pagina (View Transitions)
  document.addEventListener('astro:after-swap', initForm);
  document.addEventListener('astro:page-load', initForm);
</script>
